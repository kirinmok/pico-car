+// ── PS2 GAMEPAD (via USB adapter, standard Gamepad API) ──
+const gpState = { prevTriangle: false, prevStart: false };
+const GP_DEADZONE = 0.25;
+function pollGamepad() {
+  const gamepads = navigator.getGamepads ? navigator.getGamepads() : [];
+  const gp = gamepads[0];
+  if (!gp) return { lx: 0, ly: 0, cross: false, circle: false, square: false, triangle: false, l2: false, r2: false, start: false, dUp: false, dDown: false, dLeft: false, dRight: false };
+  const ax = v => Math.abs(v) > GP_DEADZONE ? v : 0;
+  return {
+    lx: ax(gp.axes[0]),               // 左搖桿 X
+    ly: ax(gp.axes[1]),               // 左搖桿 Y
+    cross:    gp.buttons[0]?.pressed,  // ✕ 加速
+    circle:   gp.buttons[1]?.pressed,  // ○ Boost
+    square:   gp.buttons[2]?.pressed,  // □ 煞車
+    triangle: gp.buttons[3]?.pressed,  // △ 切換視角
+    l2:       gp.buttons[6]?.pressed,  // L2 煞車
+    r2:       gp.buttons[7]?.pressed,  // R2 加速
+    start:    gp.buttons[9]?.pressed,  // Start 回首頁
+    dUp:      gp.buttons[12]?.pressed, // 十字鍵 ↑
+    dDown:    gp.buttons[13]?.pressed, // 十字鍵 ↓
+    dLeft:    gp.buttons[14]?.pressed, // 十字鍵 ←
+    dRight:   gp.buttons[15]?.pressed, // 十字鍵 →
+  };
+}
